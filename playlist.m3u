    <link rel="shortcut icon" type="image/jpg" href="../favicon.jpg"/>
    <title>CricBuzz | Live Stream</title>
    <style>
        body {
            background-color: #000;
            margin: 0;
            font-family: Arial, sans-serif;
            color: #fff;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 10px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            margin-bottom: 10px;
        }
        .channel-name {
            font-size: 1.2rem;
            font-weight: bold;
        }

        .banner {
            width: 100%;
            text-align: center;
            padding: 10px 0;
            margin: 10px 0;
        }
        .banner img {
            max-width: 100%;
            height: auto;
            border-radius: 8px;
        }
        .loading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #fff;
            font-size: 1.2rem;
        }
        .shaka-spinner-container { display: none; }
        .error {
            color: #ff4444;
            text-align: center;
            padding: 20px;
        }
        .controls {
            margin-top: 15px;
            display: flex;
            justify-content: center;
            gap: 10px;
        }
        button {
            background: #444;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 4px;
            cursor: pointer;
        }
        button:hover {
            background: #555;
        }
        .drm-badge {
            background: #333;
            color: #0af;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            margin-left: 10px;
        }
        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                gap: 10px;
            }
            .controls {
                flex-wrap: wrap;
            }
        }
        /* Simple Player Change Button */
        .player-change-section {
            text-align: center;
            padding: 15px 0;
            background: #222;
            margin-top: 20px;
        }
        
        .change-player-btn {
            background: #444;
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.9rem;
        }
        
        .change-player-btn:hover {
            background: #555;
        }
    </style>
