            <div class="controls">
                <button id="playBtn">Play</button>
                <button id="pauseBtn">Pause</button>
                <button id="fullscreenBtn">Fullscreen</button>
            </div>
        </div>
        
<div data-shaka-player-container style="max-width:100%"
         data-shaka-player-cast-receiver-id="1BA79154">
